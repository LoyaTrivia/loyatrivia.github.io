# Loya Trivia landing — Apache config (statik hosting için)
# Apache dışı bir host kullanıyorsan bu dosya yok sayılır.

# --- MIME türleri ---
AddType application/manifest+json .webmanifest
AddType image/svg+xml .svg
AddDefaultCharset UTF-8

# --- Sıkıştırma ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml text/plain
</IfModule>

# --- Önbellek ---
<IfModule mod_expires.c>
  ExpiresActive On
  # HTML'i kısa tut (içerik güncellemeleri çabuk görünsün)
  ExpiresByType text/html "access plus 0 seconds"
  # Statik varlıkları uzun tut
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  # Mağaza/ads doğrulama dosyaları taze kalsın
  ExpiresByType text/plain "access plus 1 day"
</IfModule>

# --- Güvenlik başlıkları ---
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
